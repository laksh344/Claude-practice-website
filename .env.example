# ─────────────────────────────────────────────────────────────
# Frontend (Vite) — safe to expose in the client bundle.
# Copy to .env.local and fill in. With Supabase absent the app
# runs in-memory (no persistence, no auth, no AI backend).
# ─────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

# Optional: client crash + error reporting (no-op if unset).
VITE_SENTRY_DSN=

# Optional: public Stripe publishable key (pk_...) — safe to expose.
VITE_STRIPE_PUBLISHABLE_KEY=

# ─────────────────────────────────────────────────────────────
# Server-side ONLY — set as Supabase Edge Function secrets, never
# in .env.local and never prefixed with VITE_ (would leak to client):
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#   supabase secrets set STRIPE_SECRET_KEY=sk_live_...
#   supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
#   supabase secrets set STRIPE_PRICE_PRO=price_...
#   supabase secrets set STRIPE_PRICE_MENTOR=price_...
# (SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY are injected into
#  Edge Functions automatically by the Supabase platform.)
# ─────────────────────────────────────────────────────────────
